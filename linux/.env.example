# ════════════════════════════════════════════════════════════════════════════
# Docker Compose Environment Variables
# ════════════════════════════════════════════════════════════════════════════
#
# This file shows the environment variables that docker-compose will use.
# These are automatically exported when you source config.sh
#
# DO NOT edit this file directly - instead, edit linux/config.sh
# ════════════════════════════════════════════════════════════════════════════

# Directory paths (must be absolute paths)
MODELS_DIR=/home/${USER}/.local/share/localai/models
CONFIG_DIR=/home/${USER}/.local/share/localai/config

# Docker image configuration
DOCKER_IMAGE=quay.io/go-skynet/local-ai
DOCKER_TAG=latest

# For GPU acceleration, use:
# DOCKER_TAG=latest-gpu-hipblas

# Port configuration
HTTP_PORT=8080
GRPC_PORT=5000

# CPU threads (adjust for your system)
THREADS=24

# Security: Run container as non-root user (uses your current UID/GID)
DOCKER_UID=1000
DOCKER_GID=1000
